# Copy to .env and fill in. .env is gitignored.

# Required
ANTHROPIC_API_KEY=sk-ant-...

# Optional overrides (defaults shown)
MODEL_BA=claude-sonnet-5
MODEL_TEST=claude-sonnet-5
MODEL_DEV=claude-opus-4-8
MAX_QA_ROUNDS=3
SANDBOX_TIMEOUT=60
SANDBOX_BACKEND=auto          # auto | docker | local
SANDBOX_IMAGE=agent-sandbox:py312
